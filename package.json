{
  "name": "racevis",
  "displayName": "racevis",
  "description": "Go race condition visualizer",
  "version": "0.0.3",
  "publisher": "bullish-labs",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/bramakrishna16/racevis-vscode"
  },
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Debuggers",
    "Testing"
  ],
  "galleryBanner": {
    "color": "#111111",
    "theme": "dark"
  },
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "racevis.analyze",
        "title": "racevis: Analyze current package"
      },
      {
        "command": "racevis.showOutput",
        "title": "racevis: Show output log"
      }
    ],
    "configuration": {
      "title": "racevis",
      "properties": {
        "racevis.binaryPath": {
          "type": "string",
          "default": "racevis",
          "description": "Path to the racevis binary. Defaults to 'racevis' (must be on PATH)."
        },
        "racevis.target": {
          "type": "string",
          "default": "auto",
          "description": "Go package to analyze. Use 'auto' to infer a package with _test.go files from the active Go file, or pick from discovered test packages."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.120.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "ts-loader": "^9.5.4",
    "webpack": "^5.105.3",
    "webpack-cli": "^6.0.1",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
